<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Home page -->
        <TextView style="@style/SettingsHeader" android:text="@string/settings_general" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/settings_home_page"
            app:endIconMode="clear_text">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editHomePage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchRestoreTabs"
            style="@style/SettingsSwitch"
            android:text="@string/settings_restore_tabs" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchDesktop"
            style="@style/SettingsSwitch"
            android:text="@string/settings_desktop_default" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchPersistentUrl"
            style="@style/SettingsSwitch"
            android:text="@string/settings_persistent_url" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchResumeLastPage"
            style="@style/SettingsSwitch"
            android:text="@string/settings_resume_last_page" />

        <!-- Appearance -->
        <TextView style="@style/SettingsHeader" android:text="@string/settings_appearance" />

        <RadioGroup
            android:id="@+id/themeGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton android:id="@+id/themeSystem" style="@style/SettingsRadio" android:text="@string/settings_theme_system" />
            <RadioButton android:id="@+id/themeLight" style="@style/SettingsRadio" android:text="@string/settings_theme_light" />
            <RadioButton android:id="@+id/themeDark" style="@style/SettingsRadio" android:text="@string/settings_theme_dark" />
        </RadioGroup>

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchDarkPages"
            style="@style/SettingsSwitch"
            android:text="@string/settings_dark_pages" />

        <TextView
            android:id="@+id/labelScale"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="?attr/colorOnSurface"
            android:textSize="15sp"
            android:text="@string/settings_display_scale" />

        <SeekBar
            android:id="@+id/seekScale"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:min="50"
            android:max="200" />

        <!-- Privacy -->
        <TextView style="@style/SettingsHeader" android:text="@string/settings_privacy" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchAdBlock"
            style="@style/SettingsSwitch"
            android:text="@string/settings_ad_block" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClearCleartext"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/settings_clear_cleartext" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClearData"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/settings_clear_data" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/settings_save" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
